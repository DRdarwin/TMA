generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id
  telegramId   String         @unique 
  email        String?        @unique  // додаємо email, якщо потрібен
  firstName    String?
  lastName     String?
  username     String?
  createdAt    DateTime       @default(now())
  usdtBalance  Float          @default(0.0) 
  transactions FinancialTransaction[]
  notifications Notification[]
  settings     UserSettings?  @relation("UserSettings")
}

model Flight {
  id          String    @id @default(uuid())
  departure   DateTime
  arrival     DateTime
  origin      String
  destination String
  passengers  Int       @default(1) // Ensure passengers is always at least 1 in application logic
  createdAt   DateTime  @default(now())
}

model FinancialTransaction {
  id                String            @id @default(uuid())
  userId            String
  type              TransactionType   
  amount            Float
  description       String?           @default("")
  blockchainTxHash  String?           // додане поле для збереження blockchain хешу
  createdAt         DateTime          @default(now())

  user              User              @relation(fields: [userId], references: [id])

  @@index([userId])  
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  message     String
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])  
}

model UserSettings {
  userId                String  @id
  user                  User    @relation("UserSettings", fields: [userId], references: [id])
  language              String  @default("uk-UA")
  notificationsEnabled  Boolean @default(true)
  theme                 String  @default("light")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  TRANSFER
}
